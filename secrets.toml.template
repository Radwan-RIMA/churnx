# .streamlit/secrets.toml
# ---------------------------------------------------------
# Copy this file to .streamlit/secrets.toml and fill in
# your credentials.  DO NOT commit secrets.toml to Git —
# add it to your .gitignore.
#
# On Streamlit Community Cloud, paste these values in:
#   App Settings → Secrets
# ---------------------------------------------------------

# Top-level keys (NOT under any [table]) — the app reads these directly.
LLM_PROVIDER = "groq"
GROQ_API_KEY = "gsk_your-groq-key-here"
